# Copy this file to .env and fill in the values

# IMPORTANT: Generate a strong random key for production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE_THIS_IN_PRODUCTION_USE_A_STRONG_RANDOM_KEY"

# Fernet encryption key for storing OKX API secrets
# Leave blank on first run — it will be auto-generated and saved here
ENCRYPTION_KEY=""

# SQLite database path (default: ./trading.db)
DATABASE_URL="sqlite:///./trading.db"

# JWT token expiry in minutes (default: 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 是否允许公开注册
ALLOW_REGISTER=true
